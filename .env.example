# TZStudies Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Flask
FLASK_ENV=development
SECRET_KEY=generate-with-python -c "import secrets; print(secrets.token_hex(32))"

# Database (PostgreSQL)
# For local development: postgresql://user:pass@localhost:5432/tzstudies
# For Render: provided automatically
DATABASE_URL=sqlite:///tzstudies.db

# OpenAI (for AI Study Assistant)
OPENAI_API_KEY=sk-your-key-here

# Email (Gmail SMTP — requires App Password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Redis (optional — for rate limiting in production)
# REDIS_URL=redis://localhost:6379/0
